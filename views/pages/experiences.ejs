<%- include('../partials/header') %>
    <%- include('../partials/nav') %>

        <main class="experiences-main-page">
            <section class="page-title-section">
                <div class="container">
                    <h1>Park Exhibits & Experiences</h1>
                    <p>Discover interactive adventures, wildlife encounters, and educational showcases available daily.</p>
                </div>
            </section>

            <div class="all-experiences-display">
                <div class="container">

                    <div class="search-box">
                        <input type="text" id="searchInput" placeholder="Search experiences... " autofocus>
                    </div>

                    <div class="experiences-grid" id="experiencesGrid">
                        <% if (experiences && experiences.length> 0) { %>
                            <% experiences.forEach(exp=> { %>
                                <div class="experience-card">
                                    <div class="exp-image-wrapper">
                                        <img src="/images/<%= exp.image %>" alt="<%= exp.name %>">
                                    </div>
                                    <div class="exp-content-wrapper">
                                        <h2>
                                            <%= exp.name %>
                                        </h2>
                                        <p>
                                            <%= exp.description %>
                                        </p>
                                    </div>
                                </div>
                                <% }); %>
                                    <% } else { %>
                                        <p>No experiences found.</p>
                                        <% } %>
                    </div>

                </div>
            </div>
        </main>

        <script src="/js/search.js"></script>

        <%- include('../partials/footer') %>