<%- include('../partials/header') %>
    <%- include('../partials/nav') %>

        <main class="home-main">
            <section class="hero">
                <div class="hero-overlay">
                    <div class="hero-content">
                        <h1>Welcome to Verdoliva Eco Park</h1>
                        <h2>Discover the Wonder of Nature</h2>
                        <p>Welcome to Verdoliva Eco Park—a sanctuary dedicated to wildlife conservation, environmental education, and unforgettable family adventures.</p>
                        <div class="hero-buttons">
                            <a href="/habitats" class="btn-primary">Explore Habitats</a>
                            <a href="/contact" class="btn-secondary">Plan Your Visit</a>
                        </div>
                    </div>
                </div>
            </section>

            <section class="about-section">
                <div class="container">
                    <h2>Our Mission & Vision</h2>
                    <p>At Verdoliva, we bridge the gap between human curiosity and the natural world. Inspired by world-class conservation spaces, our mission focuses entirely on protecting vulnerable species and cultivating sustainable ecological values for future generations.</p>
                </div>
            </section>

            <section class="info-highlights">
                <div class="container highlight-grid">
                    <div class="info-card clock-card">
                        <h3>Opening Times</h3>
                        <p class="time-text">Open Every Day</p>
                        <p class="hours-text">9:00 AM – 6:00 PM</p>
                        <small class="notice-text">*Last entry at 5:00 PM</small>
                    </div>

                    <div class="info-card promotional-card">
                        <h3>Park Admission</h3>
                        <p>Verdoliva Eco Park is currently operating as an educational promotional exhibit. Entry details, group bookings, and school tour allocations are handled exclusively via our direct channels.</p>
                        <p class="no-tickets-notice"><strong>Please Note:</strong> Online ticket sales or reservations are not active on this portal.</p>
                    </div>
                </div>
            </section>
        </main>

        <%- include('../partials/footer') %>