<%- include('../partials/header') %>
    <%- include('../partials/nav') %>

        <main class="contact-main">
            <section class="page-title-section">
                <div class="container">
                    <h1>Contact Us</h1>
                    <p>Get in touch with our eco-adventure park team.</p>
                </div>
            </section>

            <section class="contact-form-section">
                <div class="container">
                    <div class="form-container">

                        <% if (success) { %>
                            <div class="success-banner">
                                <h3>Thank You!</h3>
                                <p>Your message has been successfully saved to our database.</p>
                                <a href="/contact" class="btn-primary">Send Another Message</a>
                            </div>
                            <% } else { %>
                                <form action="/contact" method="POST" id="contactForm" class="park-form" novalidate>
                                    <div class="form-group">
                                        <label for="name">Full Name *</label>
                                        <input type="text" id="name" name="name" required>
                                        <small class="error-msg" id="nameError"></small>
                                    </div>

                                    <div class="form-group">
                                        <label for="email">Email Address *</label>
                                        <input type="email" id="email" name="email" required>
                                        <small class="error-msg" id="emailError"></small>
                                    </div>

                                    <div class="form-group">
                                        <label for="subject">Subject *</label>
                                        <input type="text" id="subject" name="subject" required>
                                        <small class="error-msg" id="subjectError"></small>
                                    </div>

                                    <div class="form-group">
                                        <label for="message">Message *</label>
                                        <textarea id="message" name="message" rows="5" required></textarea>
                                        <small class="error-msg" id="messageError"></small>
                                    </div>

                                    <button type="submit" class="btn-primary btn-submit">Submit Message</button>
                                </form>
                                <% } %>

                    </div>
                </div>
            </section>
        </main>

        <script src="/js/contact-validation.js"></script>

        <%- include('../partials/footer') %>